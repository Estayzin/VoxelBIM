# ═════════════════════════════════════════════════════════════════
# VOXELBIM — Configuración de Desarrollo
# ═════════════════════════════════════════════════════════════════

# Autodesk Platform Services (APS) — OAuth2
# Obtén estas credenciales en: https://developer.autodesk.com/
# 1. Ve a https://developer.autodesk.com/apps
# 2. Crea una nueva aplicación
# 3. Configura Callback URL: http://localhost:3000/app/autodesk.html
# 4. Copia los valores aquí

APS_CLIENT_ID=YOUR_CLIENT_ID_HERE
APS_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
APS_CALLBACK_URL=http://localhost:3000/app/autodesk.html

# Claude API
# Obtén tu API key en: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-YOUR_KEY_HERE

# Servidor
NODE_ENV=development
PORT=3000
